# Required — API authentication token
AGENT_API_TOKEN=replace-me

# Required — Permission approval mode: desktop | telegram | either | both
PERMISSION_MODE=desktop

# Optional — Server bind address and port
# API_HOST=127.0.0.1
# API_PORT=4317

# Optional — Permission request timeout in ms
# PERMISSION_TIMEOUT_MS=120000

# Optional — Telegram permission broker (required if PERMISSION_MODE includes telegram)
# TELEGRAM_BOT_TOKEN=123:abc
# TELEGRAM_CHAT_ID=123456789

# Optional — 1Password vault and category
ONENV_VAULT=onenv
ONENV_CATEGORY=API Credential

# Optional — 1Password service account token. When set, `op` skips biometric/desktop
# auth so agents stop triggering Touch ID prompts. Required for headless/daemon use.
# Create in 1Password web → Developer → Service Accounts. Grant read+write on the
# vault above. Accepts either a literal `ops_...` token or an `op://...` reference
# (resolved at startup via one biometric prompt). Token compromise = vault compromise.
# OP_SERVICE_ACCOUNT_TOKEN=op://Personal/<item-id>/credential
