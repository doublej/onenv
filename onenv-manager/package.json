{
  "name": "onenv-manager",
  "version": "0.4.0",
  "description": "A command-line tool",
  "author": "Jurre-Jan Smit",
  "type": "module",
  "bin": {
    "onenv": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run src",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "@clack/prompts": "^1.3.0",
    "commander": "^14.0.3",
    "ora": "^9.4.0"
  }
}
